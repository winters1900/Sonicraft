# 七牛云 AI 大模型推理 API 密钥（赛事赠送额度，从 https://developer.qiniu.com/aitokenapi/12884/how-to-get-api-key 获取）
QINIU_API_KEY=

# OpenAI 兼容基址（默认即可）
QINIU_BASE_URL=https://api.qnaigc.com/v1

# 用于指令解析的对话模型（按需替换为大模型广场中的可用模型）
QINIU_LLM_MODEL=deepseek-v3

# 七牛语音服务 WebSocket 基址
QINIU_VOICE_WS=wss://api.qnaigc.com/v1/voice

# TTS 音色
QINIU_TTS_VOICE=qiniu_zh_female_wwxkjx

# 后端监听端口
PORT=8787

# ---- 七牛对象存储 Kodo（七牛 ASR 必需）----
# 七牛 ASR 为“服务端回拉音频”模式（audio.url 必填），访问不到 localhost；
# 故录音先上传 Kodo 换公网 URL 再交 ASR。AK/SK 见控制台「密钥管理」，与上面的 AI 密钥不同。
QINIU_KODO_AK=
QINIU_KODO_SK=
QINIU_KODO_BUCKET=
QINIU_KODO_DOMAIN=
# 域名是否走 https（测试域名 clouddn.com 一般为 http）
QINIU_KODO_HTTPS=false
