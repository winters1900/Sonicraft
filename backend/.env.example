# Backend port
PORT=8787

# Hugging Face 文生图。token 在 https://huggingface.co/settings/tokens 创建（read 即可）。
# 注意：真实 token 只放 backend/.env（已 gitignore），切勿写进本示例文件！
HF_TOKEN=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGINE_TIMEOUT_MS=60000

# 文生图端点：用 HF router（Inference Providers）。旧 api-inference.huggingface.co 已停用；
# hf-mirror 只镜像文件下载、不提供推理，勿用。
HF_IMAGE_URL=https://router.huggingface.co/hf-inference/models/black-forest-labs/FLUX.1-schnell

# 国内直连不通时填 SOCKS5 代理（Clash 默认 socks5://127.0.0.1:7890）
# socks_proxy=socks5://127.0.0.1:7890

# Production CORS allowlist, comma-separated. Empty means development/open.
CORS_ORIGINS=

# Simple in-memory API rate limit.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
